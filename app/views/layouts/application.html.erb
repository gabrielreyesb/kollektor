<!DOCTYPE html>
<html>
  <head>
    <title>Kollektor</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- Vertical Navbar -->
        <nav class="vertical-navbar col-auto p-0">
          <div class="d-flex flex-column h-100">
            <!-- Logo at the top -->
            <div class="navbar-brand mb-4">
              <%= image_tag "logo.png", class: "img-fluid" %>
            </div>
            
            <!-- Main Navigation -->
            <ul class="nav flex-column mt-3">
              <li class="nav-item">
                <a class="nav-link active" href="#">Home</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Dashboard</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Profile</a>
              </li>
            </ul>

            <!-- Spacer to push management section to bottom -->
            <div class="flex-grow-1"></div>

            <!-- Management Section -->
            <div class="px-3 mb-4">
              <h6 class="text-white mb-3 text-uppercase fs-7">Management</h6>
              <ul class="nav flex-column">
                <li class="nav-item">
                  <a class="nav-link" href="#">
                    <i class="bi bi-music-note-list me-2"></i>Manage Genres
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="#">
                    <i class="bi bi-person-lines-fill me-2"></i>Manage Authors
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="#">
                    <i class="bi bi-disc me-2"></i>Manage Albums
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </nav>

        <!-- Main Content -->
        <main class="col py-3">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
